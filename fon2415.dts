// SPDX-License-Identifier: GPL-2.0-or-later OR MIT
//
// Fon Fonera Hub FON2415 (ook: FON2515A02 / Gramofon)
//
// Hardware:
//   CPU:   Atheros AR9341 (MIPS 74Kc, 535MHz)
//   RAM:   64MB DDR2 (ESMT M14D5121632A)
//   Flash: 16MB SPI NOR (MXIC MX25L128)
//   WiFi:  2.4GHz 802.11b/g/n (geïntegreerd in AR9341)
//   ETH:   2 poorten via Bi-TEK FM-1024LLF switch
//   Audio: AKM AK4430ET DAC (3.5mm jack) — I2S
//   UART:  J2 header, 115200 8N1, 3.3V TTL
//
// Flash-indeling (overeenstemmend met origineel U-Boot):
//   0x000000 - 0x01ffff  u-boot      (128KB)
//   0x020000 - 0xfdffff  firmware    (16.125MB — kernel + rootfs)
//   0xfe0000 - 0xfeffff  fon_data    (64KB)
//   0xff0000 - 0xffffff  art         (64KB, WiFi-kalibratie)
//
// U-Boot: `run lf` flitst fon2415.image naar 0x9f020000
//         `bootm 0x9f020000` start de kernel

/dts-v1/;

#include "ar9341.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	compatible = "fon,fon2415", "qca,ar9341";
	model = "Fon Fonera Hub FON2415 (Gramofon)";

	aliases {
		led-boot     = &led_status;
		led-failsafe = &led_status;
		led-running  = &led_status;
		led-upgrade  = &led_status;
		label-mac-device = &eth0;
	};

	leds {
		compatible = "gpio-leds";

		// GPIO-nummers zijn schattingen op basis van soortgelijke
		// Atheros-boards. Aanpassen na verificatie via /sys/class/gpio.
		led_status: status {
			label = "fon2415:green:status";
			gpios = <&gpio 11 GPIO_ACTIVE_LOW>;
			default-state = "on";
		};

		wifi {
			label = "fon2415:blue:wifi";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy0tpt";
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&gpio 12 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};
};

// ── SPI flash ──────────────────────────────────────────────────────────────

&spi {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <25000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x000000 0x020000>;
				read-only;
			};

			partition@20000 {
				label = "firmware";
				reg = <0x020000 0xfc0000>;
			};

			partition@fe0000 {
				label = "fon_data";
				reg = <0xfe0000 0x010000>;
				read-only;
			};

			art: partition@ff0000 {
				label = "art";
				reg = <0xff0000 0x010000>;
				read-only;
			};
		};
	};
};

// ── Ethernet ───────────────────────────────────────────────────────────────
//
// De Bi-TEK FM-1024LLF is een externe switch. Op AR9341-boards is dit
// typisch een Atheros AR8035 of vergelijkbaar, verbonden via MDIO/RGMII.
// eth0 = WAN-achtige poort, eth1 = LAN-achtige poort.
// Pas phy-adressen aan als de poorten omgewisseld zijn.

&mdio0 {
	status = "okay";

	phy0: ethernet-phy@0 {
		reg = <0>;
		// AR8035-specifiek: gigabit autoneg, geen EEE
		eee-broken-100tx;
		eee-broken-1000t;
	};
};

&mdio1 {
	status = "okay";

	phy1: ethernet-phy@1 {
		reg = <1>;
		eee-broken-100tx;
		eee-broken-1000t;
	};
};

&eth0 {
	status = "okay";
	nvmem-cells = <&macaddr_art>;
	nvmem-cell-names = "mac-address";
	phy-handle = <&phy0>;
	phy-mode = "rgmii-id";
};

&eth1 {
	status = "okay";
	nvmem-cells = <&macaddr_art>;
	nvmem-cell-names = "mac-address";
	mac-address-increment = <1>;
	phy-handle = <&phy1>;
	phy-mode = "gmii";
};

// ── WiFi ───────────────────────────────────────────────────────────────────
//
// WiFi-kalibratie zit in de ART-partitie op offset 0x1000.
// Dit is het standaard Atheros-patroon voor AR9341.

&wmac {
	status = "okay";
	mtd-cal-data = <&art 0x1000>;
};

// ── MAC-adres uit ART ──────────────────────────────────────────────────────

&art {
	nvmem-layout {
		compatible = "fixed-layout";
		#address-cells = <1>;
		#size-cells = <1>;

		macaddr_art: macaddr@0 {
			reg = <0x0 0x6>;
		};
	};
};
